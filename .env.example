MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_USER=admin
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=saas_master_db

DB_HOST=mysql-master
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your_password
DB_NAME=saas_master_db

REDIS_URL=redis://redis-broker:6379

JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
GEMINI_API_KEY=your_google_gemini_api_key_from_aistudio
BREVO_API_KEY=your_brevo_api_key

RUN_SEED=false

# Master DB name (used by tenantStatusMiddleware)
MASTER_DB_NAME=saas_master_db

# Frontend (Vite build-time fallback - runtime detection handles local vs prod)
VITE_API_BASE_URL=http://api.localhost
